# Tu string de conexión para MongoDB
MONGO_URI=mongodb+srv://<usuario>:<contraseña>@<cluster-url>/<database>?retryWrites=true&w=majority&appName=<app-name>

# URL del cliente. Default: http://localhost:3000
FRONTEND_URL=

# Puerto del servidor. Default: 4000
PORT=

# Configuración de firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
